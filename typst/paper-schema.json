{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Typst IEEE Paper Schema",
  "description": "Schema for generating an IEEE academic paper using the charged-ieee Typst template.",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "The main title of the research paper."
    },
    "abstract": {
      "type": "string",
      "description": "A brief summary of the research paper."
    },
    "index_terms": {
      "type": "array",
      "description": "Keywords or index terms for the paper.",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "authors": {
      "type": "array",
      "description": "List of authors contributing to the paper.",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Full name of the author."
          },
          "department": {
            "type": "string",
            "description": "Author's department (e.g., Computer Science)."
          },
          "organization": {
            "type": "string",
            "description": "Author's university or company."
          },
          "location": {
            "type": "string",
            "description": "City and Country of the organization."
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Author's contact email."
          }
        },
        "required": ["name", "organization", "email"]
      },
      "minItems": 1
    },
    "sections": {
      "type": "array",
      "description": "The main body sections of the document.",
      "items": {
        "type": "object",
        "properties": {
          "heading": {
            "type": "string",
            "description": "The title of the section (e.g., Introduction, Methodology)."
          },
          "content": {
            "type": "string",
            "description": "The text content of the section. Supports Typst markup."
          }
        },
        "required": ["heading", "content"]
      },
      "minItems": 1
    }
  },
  "required": ["title", "abstract", "authors", "sections"]
}