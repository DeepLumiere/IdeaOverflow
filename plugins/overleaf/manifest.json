{
  "manifest_version": 3,
  "name": "IdeaOverflow - Overleaf AI Assistant",
  "version": "1.0.0",
  "description": "AI-powered research assistant for Overleaf with chat, autocomplete, review, and editing features",
  "permissions": [
    "activeTab",
    "storage",
    "clipboardWrite"
  ],
  "host_permissions": [
    "*://*.overleaf.com/*",
    "http://localhost:8000/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "64": "icons/64.png",
    "128": "icons/128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.overleaf.com/project/*"
      ],
      "css": [
        "styles.css"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "logo.svg"
      ],
      "matches": [
        "*://*.overleaf.com/*"
      ]
    }
  ]
}